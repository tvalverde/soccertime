# =============================================================================
# Django Environment Configuration
# =============================================================================
# Copy this file to:
#   - .env              (for development)
#   - .env.production   (for production)
# And adjust values accordingly.
# =============================================================================

# -----------------------------------------------------------------------------
# Core Settings
# -----------------------------------------------------------------------------

# Debug mode: true for development, false for production
DJANGO_DEBUG=true                    # Production: false

# Enable template and view caching: false for development, true for production
DJANGO_CACHE=false                   # Production: true

# Enable Django admin interface
DJANGO_ADMIN_ENABLED=true

# -----------------------------------------------------------------------------
# Hosts & Security
# -----------------------------------------------------------------------------

# Comma-separated list of allowed hosts
DJANGO_ALLOWED_HOSTS=localhost       # Production: your-domain.com

# CSRF trusted origins (required in production)
# DJANGO_CSRF_TRUSTED_ORIGINS=       # Production: https://your-domain.com

# -----------------------------------------------------------------------------
# Static & Media Files
# -----------------------------------------------------------------------------

# Static files URL and root directory
DJANGO_STATIC_URL=                   # Production: /soccertime/static/
DJANGO_STATIC_ROOT=                  # Production: /code/static

# Media files URL and root directory
DJANGO_MEDIA_URL=                    # Production: /soccertime/media/
DJANGO_MEDIA_ROOT=                   # Production: /code/media/

# -----------------------------------------------------------------------------
# Proxy Settings (for reverse proxy setups)
# -----------------------------------------------------------------------------

# Trust X-Forwarded-Host header
DJANGO_USE_X_FORWARDED_HOST=false    # Production: true

# Force script name (URL prefix)
DJANGO_FORCE_SCRIPT_NAME=            # Production: /soccertime

# Session cookie path
DJANGO_SESSION_COOKIE_PATH=/         # Production: /soccertime/

# -----------------------------------------------------------------------------
# Database & Cache
# -----------------------------------------------------------------------------

# SQLite database path
DJANGO_DATABASE_DEFAULT_NAME=/code/db/db.sqlite3

# Requests cache path
REQUESTS_CACHE=/code/soccertime_data_cache.sqlite


# -----------------------------------------------------------------------------
# Deployment Configuration (Makefile)
# -----------------------------------------------------------------------------

# Remote server host (e.g., user@domain.com)
REMOTE_HOST=user@example.com

# Remote server SSH port
REMOTE_PORT=22

# Remote path where the application will be deployed
REMOTE_PATH=/path/to/deploy
